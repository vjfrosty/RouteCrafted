{
  "name": "mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "build": "node -e \"if(process.env.SKIP_MOBILE_BUILD==='true'){console.log('Skipping mobile build (SKIP_MOBILE_BUILD=true)');process.exit(0)}require('child_process').execSync('expo export',{stdio:'inherit'});\"",
    "lint": "expo lint"
  },
  "dependencies": {
    "expo": "53.0.0",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.84.0",
    "@expo/vector-icons": "^14.0.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "typescript": "^5.3.3"
  }
}
