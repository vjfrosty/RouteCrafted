# .env.example — copy to .env.local and fill values. NEVER commit secrets.
# For production, set these in your hosting dashboard (Vercel, Cloudflare, etc.).
# "Source:" lines indicate where to obtain each secret or token.

### Database
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require
# Source: Neon (https://neon.tech) or your Postgres provider. Production: set in your host.

### Auth (NextAuth / JWT)
NEXTAUTH_SECRET=replace-with-random-secret
# Generate a secure value with: openssl rand -base64 32
# Source: used by NextAuth / JWT signing — store securely in host (Vercel/Cloudflare).

AUTH_SECRET=            # optional alias for NEXTAUTH_SECRET
NEXTAUTH_URL=http://localhost:3000
# Set to your app URL in production (e.g. https://routecrafted.com)

### AI / LLM
OPENROUTER_API_KEY=your-openrouter-api-key
# Source: https://openrouter.ai — keep this secret server-side.
OPENROUTER_MODEL=deepseek/deepseek-chat
# Optional: override the default OpenRouter model identifier.

# Alternative / optional LLM keys (only if you use them)
GEMINI_API_KEY=
# Source: Google Generative AI (https://developers.google.com/ai) — optional
GROQ_API_KEY=
# Source: https://console.groq.com — optional fallback

### Places / POI (optional)
OPENTRIPMAP_KEY=your-opentripmap-key
# Source: https://opentripmap.io — optional enrichment (app degrades if missing).

### Mapbox (client-side public)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token
# Public token — safe to expose to the browser. Get from https://www.mapbox.com

### Cloudflare R2 (object storage)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=routecrafted-uploads
R2_PUBLIC_URL=https://pub.example.com
# Source: Cloudflare dashboard → R2. Keep keys secret; do NOT expose to client-side code.

### Email (Resend)
RESEND_API_KEY=your_resend_api_key
# Source: https://resend.com — used for transactional emails (welcome, alerts).

### Mobile / Expo
EXPO_PUBLIC_API_URL=http://localhost:3000
# Base API URL used by the Expo mobile app. In production set to your deployed URL.

### Admin seed (dev only)
ADMIN_EMAIL=admin@routecrafted.com
ADMIN_PASSWORD=change-this-password
ADMIN_NAME=Admin

### Toggle (temporary)
# Set to "true" to disable new user registrations without changing code.
DISABLE_SIGNUP=false
# If you want the client UI to hide the register form, set the public flag too:
NEXT_PUBLIC_DISABLE_SIGNUP=false

### Notes / Optional
# - Never commit .env.local or .env.example with real secrets.
# - For production, add these variables in your host's environment settings (e.g., Vercel Dashboard → Settings → Environment Variables).
# - `NEXT_PUBLIC_` prefixes are exposed client-side; only include public-safe tokens there.
# - If optional keys (like OPENTRIPMAP_KEY) are absent the app will skip/enrich features gracefully.
